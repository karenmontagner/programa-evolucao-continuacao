
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Plano de Evolução Contínua · 14 dias · Semana 05 · Luciana Bonome · Mentoria Karen Montagner</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy-900:  #0B1733;
    --navy-800:  #0F1E3D;
    --navy-700:  #17294F;
    --navy-500:  #2A3E6C;
    --gold-500:  #C9A353;
    --gold-400:  #D6B873;
    --gold-100:  #F5EAD0;
    --terra-500: #B8624A;
    --terra-400: #CF8064;
    --ivory:     #FBF8F2;
    --sand-50:   #FAF5EA;
    --sand-100:  #F5EEE0;
    --ink:       #1C1C1C;
    --muted:     #6C6A66;
    --line:      #E6DFCF;
    --creme-txt: #FBF5E4;
    --green-500: #4A7C59;

    --page-bg:   #FBF8F2;
    --text-body: #2A2A2A;
    --text-dim:  #6C6A66;
    --line-soft: rgba(11,23,51,0.1);

    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'Inter', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--page-bg);
    font-family: var(--sans);
    color: var(--text-body);
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ═══════ MASTHEAD ═══════ */
  .masthead {
    background: linear-gradient(135deg, var(--navy-900) 0%, var(--navy-700) 60%, var(--navy-500) 100%);
    padding: 56px 64px 52px;
    border-bottom: 3px solid var(--gold-500);
    position: relative;
    overflow: hidden;
  }
  .masthead::before {
    content: '';
    position: absolute;
    top: -80px; right: -60px;
    width: 380px; height: 380px;
    background: radial-gradient(circle, rgba(201,163,83,0.22), transparent 65%);
    filter: blur(24px);
  }
  .masthead::after {
    content: '';
    position: absolute;
    bottom: -120px; left: -80px;
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(184,98,74,0.15), transparent 65%);
    filter: blur(28px);
  }
  .mast-inner { position: relative; z-index: 2; max-width: 1280px; margin: 0 auto; }
  .mast-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 48px;
  }
  .mast-brand {
    font-family: var(--serif);
    font-size: 14px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold-400);
    font-weight: 400;
  }
  .mast-brand strong { color: var(--creme-txt); font-weight: 500; margin-left: 2px; }
  .mast-program {
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    color: rgba(251,245,228,0.55);
    letter-spacing: 0.8px;
  }
  .mast-program span { color: var(--gold-400); }
  .mast-eyebrow {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold-400);
    margin-bottom: 14px;
    font-weight: 500;
  }
  .mast-title {
    font-family: var(--serif);
    font-size: clamp(46px, 7vw, 80px);
    font-weight: 500;
    line-height: 1;
    color: var(--creme-txt);
    letter-spacing: -0.6px;
    margin-bottom: 22px;
  }
  .mast-title em { color: var(--gold-400); font-style: italic; font-weight: 400; }
  .mast-sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 19px;
    color: rgba(251,245,228,0.78);
    letter-spacing: 0.3px;
    max-width: 780px;
    line-height: 1.5;
    margin-bottom: 36px;
  }
  .mast-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0;
    border-top: 1px solid rgba(201,163,83,0.25);
    border-bottom: 1px solid rgba(201,163,83,0.25);
    padding: 18px 0;
  }
  .mast-meta-item {
    padding: 0 20px;
    border-right: 1px solid rgba(201,163,83,0.15);
  }
  .mast-meta-item:last-child { border-right: none; }
  .mast-meta-item:first-child { padding-left: 0; }
  .mast-meta-label {
    font-size: 8px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(201,163,83,0.6);
    margin-bottom: 6px;
    font-weight: 500;
  }
  .mast-meta-value {
    font-family: var(--serif);
    font-size: 17px;
    color: var(--creme-txt);
    font-weight: 500;
  }
  .mast-meta-value em { font-style: italic; color: var(--gold-400); font-weight: 400; }

  /* ═══════ INTRO STRIP ═══════ */
  .intro-strip {
    background: var(--sand-100);
    color: var(--navy-900);
    padding: 28px 64px;
    border-bottom: 1px solid var(--line);
  }
  .intro-strip-inner {
    max-width: 1280px;
    margin: 0 auto;
    font-family: var(--serif);
    font-style: italic;
    font-size: 19px;
    letter-spacing: 0.2px;
    line-height: 1.5;
    text-align: center;
  }
  .intro-strip-inner strong {
    font-style: normal;
    color: var(--gold-500);
    font-weight: 600;
    letter-spacing: 2.5px;
    font-size: 10px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 10px;
  }

  /* ═══════ DIAGNÓSTICO LISTA ALFA ═══════ */
  .diagnostico {
    background: var(--navy-800);
    padding: 48px 64px;
    border-bottom: 1px solid var(--gold-500);
    color: var(--creme-txt);
  }
  .diag-inner { max-width: 1280px; margin: 0 auto; }
  .diag-eyebrow {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold-400);
    margin-bottom: 14px;
    font-weight: 500;
  }
  .diag-title {
    font-family: var(--serif);
    font-size: 32px;
    font-weight: 500;
    color: var(--creme-txt);
    line-height: 1.15;
    margin-bottom: 16px;
    letter-spacing: -0.3px;
  }
  .diag-title em { font-style: italic; color: var(--gold-400); font-weight: 400; }
  .diag-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: 17px;
    color: rgba(251,245,228,0.78);
    max-width: 780px;
    margin-bottom: 32px;
    line-height: 1.5;
  }
  .diag-lede strong { color: var(--gold-400); font-weight: 500; font-style: normal; }
  .diag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0;
    border: 1px solid rgba(201,163,83,0.3);
  }
  .diag-card {
    padding: 22px 24px;
    border-right: 1px solid rgba(201,163,83,0.18);
    border-bottom: 1px solid rgba(201,163,83,0.18);
  }
  .diag-card:last-child { border-right: none; }
  .diag-card-label {
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(201,163,83,0.7);
    margin-bottom: 10px;
    font-weight: 500;
  }
  .diag-value {
    font-family: var(--serif);
    font-size: 36px;
    font-weight: 500;
    line-height: 1;
    color: var(--gold-400);
    font-style: italic;
    margin-bottom: 4px;
  }
  .diag-delta {
    font-size: 11px;
    letter-spacing: 0.5px;
    color: var(--green-500);
    font-weight: 600;
  }
  .diag-delta.warn { color: var(--terra-400); }
  .diag-delta.flat { color: rgba(251,245,228,0.5); }

  /* ═══════ PROGRESS ═══════ */
  .progress-wrap {
    background: rgba(251,248,242,0.94);
    border-bottom: 1px solid var(--line-soft);
    padding: 20px 64px;
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
  }
  .progress-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .progress-label {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--navy-900);
    white-space: nowrap;
    font-weight: 600;
  }
  .progress-bar {
    flex: 1;
    height: 3px;
    background: rgba(11,23,51,0.08);
    position: relative;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold-500), var(--terra-500));
    width: 0%;
    transition: width 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .progress-pct {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 22px;
    color: var(--navy-900);
    min-width: 64px;
    text-align: right;
    letter-spacing: 0.5px;
  }
  .actions { display: flex; gap: 10px; }
  .btn {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 11px 18px;
    background: transparent;
    color: var(--navy-900);
    border: 1px solid rgba(11,23,51,0.3);
    cursor: pointer;
    transition: all 0.25s;
    font-weight: 500;
  }
  .btn:hover { background: var(--navy-900); color: var(--creme-txt); border-color: var(--navy-900); }
  .btn-primary {
    background: var(--navy-900);
    color: var(--gold-400);
    border-color: var(--navy-900);
    font-weight: 600;
  }
  .btn-primary:hover { background: var(--gold-500); color: var(--navy-900); border-color: var(--gold-500); }

  /* ═══════ MAIN ═══════ */
  main { max-width: 1280px; margin: 0 auto; padding: 80px 64px; }
  .section { margin-bottom: 96px; }
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 14px;
  }
  .section-num {
    font-family: var(--serif);
    font-size: 12px;
    letter-spacing: 3.5px;
    color: var(--gold-500);
    font-weight: 600;
  }
  .section-kicker {
    font-family: var(--serif);
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }
  .section-rule {
    height: 1px;
    background: var(--line-soft);
    margin-bottom: 40px;
  }
  .section-title {
    font-family: var(--serif);
    font-size: clamp(38px, 5vw, 56px);
    font-weight: 500;
    color: var(--navy-900);
    line-height: 1;
    letter-spacing: -0.5px;
    margin-bottom: 24px;
  }
  .section-title em { font-style: italic; color: var(--gold-500); font-weight: 400; }
  .section-intro {
    font-size: 15.5px;
    line-height: 1.7;
    color: var(--text-body);
    max-width: 780px;
    margin-bottom: 48px;
    border-left: 2px solid var(--gold-500);
    padding-left: 22px;
  }
  .section-intro strong { color: var(--navy-900); font-weight: 600; }
  .section-intro em {
    font-style: italic;
    color: var(--terra-500);
    font-family: var(--serif);
    font-size: 17px;
  }

  /* ═══════ DESTRAVAR LISTA ALFA ═══════ */
  .destravar {
    background: white;
    border: 1px solid var(--line);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(11,23,51,0.04);
  }
  .destravar-row {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 0;
    border-bottom: 1px solid var(--line);
  }
  .destravar-row:last-child { border-bottom: none; }
  .destravar-label-cell {
    background: var(--sand-50);
    padding: 24px;
    border-right: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .destravar-tag {
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold-500);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .destravar-name {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 600;
    color: var(--navy-900);
    line-height: 1.15;
    letter-spacing: -0.3px;
    margin-bottom: 4px;
  }
  .destravar-name em { font-style: italic; color: var(--terra-500); font-weight: 500; }
  .destravar-meta {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }
  .destravar-content {
    padding: 24px 28px;
  }
  .destravar-list {
    list-style: none;
  }
  .destravar-list li {
    font-size: 14px;
    line-height: 1.65;
    padding: 10px 0;
    border-bottom: 1px dashed rgba(11,23,51,0.08);
    color: var(--text-body);
  }
  .destravar-list li:last-child { border-bottom: none; }
  .destravar-list li strong { color: var(--navy-900); font-weight: 600; }
  .destravar-list li em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--terra-500);
    font-size: 15px;
  }
  .destravar-script {
    background: var(--sand-50);
    border-left: 2px solid var(--gold-500);
    padding: 14px 18px;
    margin-top: 12px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink);
  }
  .destravar-script .placeholder {
    background: rgba(201,163,83,0.2);
    color: #8E6F2E;
    padding: 1px 6px;
    font-style: normal;
    font-weight: 500;
    font-family: var(--sans);
    font-size: 12.5px;
    letter-spacing: 0.3px;
  }

  /* ═══════ NOVOS MOVIMENTOS ═══════ */
  .strategy-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--line);
    background: white;
  }
  .strategy-card {
    padding: 32px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    position: relative;
  }
  .strategy-card:nth-child(2n) { border-right: none; }
  .strategy-card:nth-last-child(-n+2) { border-bottom: none; }
  .strategy-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 56px;
    height: 2px;
    background: var(--gold-500);
  }
  .strat-num {
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    color: var(--gold-500);
    margin-bottom: 8px;
    font-weight: 600;
    letter-spacing: 1px;
  }
  .strat-title {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 600;
    color: var(--navy-900);
    margin-bottom: 14px;
    line-height: 1.2;
    letter-spacing: -0.3px;
  }
  .strat-title em { font-style: italic; color: var(--terra-500); font-weight: 500; }
  .strat-body {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-body);
  }
  .strat-body strong { color: var(--navy-900); font-weight: 600; }
  .strat-body em {
    font-family: var(--serif);
    font-size: 16px;
    font-style: italic;
    color: var(--terra-500);
  }

  /* ═══════ MULTICARE ═══════ */
  .multicare-block {
    background: linear-gradient(135deg, var(--navy-900), var(--navy-700));
    border: 1px solid var(--gold-500);
    padding: 44px 48px;
    position: relative;
    overflow: hidden;
    color: var(--creme-txt);
  }
  .multicare-block::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 240px; height: 240px;
    background: radial-gradient(circle, rgba(201,163,83,0.22), transparent 65%);
    filter: blur(20px);
  }
  .multicare-inner { position: relative; z-index: 2; }
  .mc-eyebrow {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold-400);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .mc-title {
    font-family: var(--serif);
    font-size: 32px;
    font-weight: 500;
    color: var(--creme-txt);
    line-height: 1.15;
    margin-bottom: 14px;
    letter-spacing: -0.3px;
  }
  .mc-title em { font-style: italic; color: var(--gold-400); font-weight: 400; }
  .mc-context {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: rgba(251,245,228,0.78);
    line-height: 1.55;
    margin-bottom: 28px;
    max-width: 780px;
  }
  .mc-context strong { color: var(--gold-400); font-weight: 500; font-style: normal; }
  .mc-frentes {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .mc-frente {
    border-top: 1px solid rgba(201,163,83,0.3);
    padding-top: 18px;
  }
  .mc-frente-label {
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold-400);
    margin-bottom: 8px;
    font-weight: 600;
  }
  .mc-frente-title {
    font-family: var(--serif);
    font-size: 19px;
    font-weight: 600;
    color: var(--creme-txt);
    margin-bottom: 10px;
    letter-spacing: -0.2px;
  }
  .mc-frente-title em { font-style: italic; color: var(--gold-400); font-weight: 400; }
  .mc-frente-text {
    font-size: 13.5px;
    line-height: 1.65;
    color: rgba(251,245,228,0.88);
  }
  .mc-frente-text strong { color: var(--creme-txt); font-weight: 500; }
  .mc-script-box {
    background: rgba(251,245,228,0.06);
    border-left: 2px solid var(--gold-500);
    padding: 16px 20px;
    margin-top: 12px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    line-height: 1.6;
    color: var(--creme-txt);
  }
  .mc-script-box .placeholder {
    background: rgba(201,163,83,0.25);
    color: var(--gold-400);
    padding: 1px 6px;
    font-style: normal;
    font-weight: 500;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.3px;
  }

  /* ═══════ PIPELINE ═══════ */
  .pipeline-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0;
    border: 1px solid var(--line);
    background: white;
  }
  .pipeline-card {
    padding: 26px 22px;
    border-right: 1px solid var(--line);
    transition: background 0.3s;
  }
  .pipeline-card:last-child { border-right: none; }
  .pipeline-card:hover { background: var(--sand-50); }
  .pipeline-priority {
    font-family: var(--serif);
    font-style: italic;
    font-size: 11px;
    color: var(--gold-500);
    font-weight: 600;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .pipeline-name {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 22px;
    color: var(--navy-900);
    margin-bottom: 8px;
    letter-spacing: -0.3px;
    line-height: 1.1;
  }
  .pipeline-meta {
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--terra-500);
    margin-bottom: 14px;
    font-weight: 600;
  }
  .pipeline-action {
    font-size: 13px;
    line-height: 1.55;
    color: var(--text-body);
  }
  .pipeline-action strong { color: var(--navy-900); font-weight: 600; }

  /* ═══════ POSTS ═══════ */
  .posts-strategy {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .post-card {
    background: white;
    border: 1px solid var(--line);
    padding: 30px;
    position: relative;
    box-shadow: 0 2px 12px rgba(11,23,51,0.04);
  }
  .post-card::before {
    content: attr(data-num);
    position: absolute;
    top: 22px;
    right: 22px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 42px;
    color: rgba(201,163,83,0.25);
    line-height: 1;
  }
  .post-day {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--terra-500);
    margin-bottom: 8px;
    font-weight: 600;
  }
  .post-type {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 600;
    color: var(--navy-900);
    margin-bottom: 4px;
    line-height: 1.2;
  }
  .post-type em { font-style: italic; color: var(--gold-500); font-weight: 500; }
  .post-purpose {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 18px;
    font-weight: 600;
  }
  .post-gancho {
    background: var(--sand-50);
    border-left: 2px solid var(--gold-500);
    padding: 14px 16px;
    margin-bottom: 16px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink);
  }
  .post-desc {
    font-size: 13px;
    line-height: 1.65;
    color: var(--text-body);
  }
  .post-desc strong { color: var(--navy-900); font-weight: 600; }

  /* ═══════ DAYS ═══════ */
  .day {
    border-top: 1px solid var(--line-soft);
    padding: 48px 0;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 56px;
    page-break-inside: avoid;
  }
  .day:last-child { border-bottom: 1px solid var(--line-soft); }
  .day-header { position: sticky; top: 100px; align-self: start; }
  .day-date {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold-500);
    margin-bottom: 8px;
    font-weight: 600;
  }
  .day-name {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: 56px;
    line-height: 1;
    color: var(--navy-900);
    letter-spacing: -0.5px;
    margin-bottom: 6px;
  }
  .day-number {
    font-family: var(--serif);
    font-size: 12px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .day-focus {
    font-family: var(--serif);
    font-style: italic;
    font-size: 15px;
    color: var(--terra-500);
    line-height: 1.4;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--line-soft);
  }
  .day-progress {
    margin-top: 20px;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .day-progress .count {
    font-family: var(--serif);
    color: var(--gold-500);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 1px;
  }
  .day-body { display: flex; flex-direction: column; gap: 24px; }

  .block {
    background: white;
    border: 1px solid var(--line);
    padding: 30px;
    position: relative;
    box-shadow: 0 2px 12px rgba(11,23,51,0.04);
  }
  .block::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 48px; height: 2px;
    background: var(--gold-500);
  }
  .block.priority::before { background: var(--terra-500); width: 80px; }
  .block-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--line);
  }
  .block-title {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 600;
    color: var(--navy-900);
    letter-spacing: -0.2px;
  }
  .block-title em { font-style: italic; color: var(--gold-500); font-weight: 500; }
  .block.priority .block-title em { color: var(--terra-500); }
  .block-time {
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--terra-500);
    font-weight: 600;
  }

  /* ═══════ TASKS ═══════ */
  .task {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px dashed rgba(11,23,51,0.1);
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .task:last-child { border-bottom: none; }
  .task.done { opacity: 0.4; }
  .task.done .task-text {
    text-decoration: line-through;
    text-decoration-thickness: 1px;
    text-decoration-color: rgba(11,23,51,0.4);
  }
  .checkbox {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border: 1.5px solid var(--navy-900);
    background: transparent;
    cursor: pointer;
    position: relative;
    transition: all 0.25s;
    margin-top: 2px;
  }
  .checkbox:hover { background: rgba(11,23,51,0.05); }
  .task.done .checkbox {
    background: var(--navy-900);
    border-color: var(--navy-900);
  }
  .task.done .checkbox::after {
    content: '';
    position: absolute;
    left: 5px; top: 1px;
    width: 6px; height: 11px;
    border: solid var(--gold-400);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .task-content { flex: 1; }
  .task-text {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--text-body);
    margin-bottom: 6px;
  }
  .task-text strong { color: var(--navy-900); font-weight: 600; }
  .task-text em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--terra-500);
    font-size: 16px;
  }
  .task-meta {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .task-tag {
    display: inline-block;
    padding: 3px 9px;
    font-size: 8.5px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 600;
  }
  .tag-alfa { background: rgba(201,163,83,0.12); color: #8E6F2E; border: 1px solid rgba(201,163,83,0.35); }
  .tag-content { background: rgba(11,23,51,0.06); color: var(--navy-900); border: 1px solid rgba(11,23,51,0.2); }
  .tag-warm { background: rgba(184,98,74,0.1); color: var(--terra-500); border: 1px solid rgba(184,98,74,0.3); }
  .tag-news { background: rgba(245,234,208,0.5); color: #8E6F2E; border: 1px solid rgba(201,163,83,0.3); }
  .tag-call { background: rgba(74,124,89,0.12); color: var(--green-500); border: 1px solid rgba(74,124,89,0.4); }
  .tag-multicare { background: var(--terra-500); color: var(--creme-txt); border: 1px solid var(--terra-500); }
  .tag-pipe { background: rgba(74,124,89,0.18); color: var(--green-500); border: 1px solid rgba(74,124,89,0.4); }
  .tag-inmail { background: var(--navy-900); color: var(--gold-400); border: 1px solid var(--navy-900); }
  .tag-milestone { background: var(--navy-900); color: var(--gold-400); border: 1px solid var(--navy-900); }
  .tag-destravar { background: rgba(184,98,74,0.18); color: var(--terra-500); border: 1px solid var(--terra-500); }

  /* ═══════ HOWTO ═══════ */
  .howto {
    background: var(--sand-50);
    border-left: 3px solid var(--terra-500);
    padding: 20px 24px;
    margin-top: 12px;
    margin-bottom: 8px;
  }
  .howto-label {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--terra-500);
    margin-bottom: 10px;
    font-weight: 700;
  }
  .howto-body {
    font-family: var(--serif);
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink);
  }
  .howto-body strong { font-weight: 600; color: var(--navy-900); }
  .howto-body em { font-style: italic; color: var(--terra-500); }

  /* ═══════ INMAIL ═══════ */
  .inmail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .inmail-card {
    background: white;
    border: 1px solid var(--line);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(11,23,51,0.04);
  }
  .inmail-header {
    background: var(--navy-900);
    color: var(--creme-txt);
    padding: 18px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid var(--gold-500);
  }
  .inmail-title {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 500;
  }
  .inmail-title em { font-style: italic; color: var(--gold-400); font-weight: 400; }
  .inmail-tag {
    font-size: 9px;
    letter-spacing: 2.5px;
    color: var(--gold-400);
    border: 1px solid var(--gold-500);
    padding: 5px 12px;
    font-weight: 600;
  }
  .inmail-body {
    padding: 26px 28px;
    font-family: var(--serif);
    font-size: 15px;
    line-height: 1.7;
    font-style: italic;
    color: var(--ink);
    white-space: pre-wrap;
  }
  .inmail-body .placeholder {
    background: rgba(201,163,83,0.2);
    color: #8E6F2E;
    padding: 1px 6px;
    font-style: normal;
    font-weight: 600;
    font-family: var(--sans);
    font-size: 12.5px;
    letter-spacing: 0.3px;
  }

  /* ═══════ METRICS ═══════ */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0;
    border: 1px solid var(--line);
    background: white;
  }
  .metric-card {
    padding: 28px 22px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .metric-card:last-child { border-right: none; }
  .metric-label {
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold-500);
    margin-bottom: 14px;
    font-weight: 600;
  }
  .metric-input {
    width: 100%;
    padding: 4px 0;
    font-family: var(--serif);
    font-size: 42px;
    font-weight: 500;
    font-style: italic;
    color: var(--navy-900);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--line);
    margin-bottom: 8px;
    outline: none;
  }
  .metric-input:focus { border-bottom-color: var(--gold-500); }
  .metric-target {
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--terra-500);
    font-weight: 600;
  }

  /* ═══════ FOOTER ═══════ */
  footer {
    background: var(--navy-900);
    border-top: 1px solid var(--gold-500);
    padding: 56px 64px;
    margin-top: 48px;
  }
  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }
  .footer-brand {
    font-family: var(--serif);
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold-400);
  }
  .footer-brand strong { color: var(--creme-txt); font-weight: 500; }
  .footer-quote {
    font-family: var(--serif);
    font-style: italic;
    font-size: 17px;
    color: var(--creme-txt);
    letter-spacing: 0.3px;
  }
  .footer-quote em { color: var(--gold-400); }
  .footer-date {
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(201,163,83,0.5);
  }

  /* ═══════ CALL BRIEFING ═══════ */
  .call-briefing {
    background: white;
    border: 1px solid var(--line);
    margin-bottom: 28px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(11,23,51,0.04);
  }
  .briefing-header {
    background: var(--navy-900);
    color: var(--creme-txt);
    padding: 24px 32px;
    border-bottom: 2px solid var(--gold-500);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
    flex-wrap: wrap;
  }
  .briefing-info {
    flex: 1;
    min-width: 240px;
  }
  .briefing-when {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold-400);
    font-weight: 600;
    margin-bottom: 6px;
  }
  .briefing-name {
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 600;
    color: var(--creme-txt);
    line-height: 1.15;
    margin-bottom: 6px;
    letter-spacing: -0.3px;
  }
  .briefing-name em { font-style: italic; color: var(--gold-400); font-weight: 500; }
  .briefing-role {
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    color: rgba(251,245,228,0.7);
  }
  .briefing-status {
    text-align: right;
  }
  .briefing-status-tag {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold-400);
    border: 1px solid var(--gold-500);
    padding: 6px 12px;
    font-weight: 600;
    display: inline-block;
  }
  .briefing-body {
    padding: 32px;
  }
  .briefing-section {
    margin-bottom: 26px;
  }
  .briefing-section:last-child { margin-bottom: 0; }
  .briefing-section-label {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--terra-500);
    margin-bottom: 10px;
    font-weight: 700;
  }
  .briefing-section-title {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--navy-900);
    margin-bottom: 12px;
    letter-spacing: -0.2px;
  }
  .briefing-section-title em { font-style: italic; color: var(--terra-500); font-weight: 500; }
  .briefing-script {
    background: var(--sand-50);
    border-left: 2px solid var(--gold-500);
    padding: 16px 20px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .briefing-list {
    list-style: none;
    padding-left: 0;
  }
  .briefing-list li {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-body);
    padding: 10px 0;
    border-bottom: 1px dashed rgba(11,23,51,0.08);
    display: flex;
    gap: 12px;
  }
  .briefing-list li:last-child { border-bottom: none; }
  .briefing-list li::before {
    content: '→';
    color: var(--terra-500);
    font-weight: 700;
    flex-shrink: 0;
  }
  .briefing-list li strong { color: var(--navy-900); font-weight: 600; }
  .briefing-list li em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--terra-500);
    font-size: 16px;
  }
  .briefing-questions {
    counter-reset: question;
    list-style: none;
    padding-left: 0;
  }
  .briefing-questions li {
    counter-increment: question;
    padding: 14px 0 14px 38px;
    border-bottom: 1px dashed rgba(11,23,51,0.08);
    position: relative;
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink);
  }
  .briefing-questions li:last-child { border-bottom: none; }
  .briefing-questions li::before {
    content: counter(question);
    position: absolute;
    left: 0;
    top: 14px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    color: var(--gold-500);
    font-weight: 600;
    line-height: 1;
  }
  .briefing-questions li strong {
    display: block;
    font-style: normal;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    margin-top: 4px;
  }
  .briefing-warning {
    background: rgba(184,98,74,0.08);
    border-left: 2px solid var(--terra-500);
    padding: 14px 18px;
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-body);
  }
  .briefing-warning strong { color: var(--terra-500); font-weight: 600; }

  /* ═══════ CAPTURA PÓS-CALL ═══════ */
  .captura-block {
    background: var(--sand-50);
    border: 1px solid var(--line);
    border-top: 3px solid var(--green-500);
    padding: 28px 32px;
    margin-top: 0;
  }
  .captura-label {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--green-500);
    margin-bottom: 14px;
    font-weight: 700;
  }
  .captura-title {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 600;
    color: var(--navy-900);
    margin-bottom: 6px;
    letter-spacing: -0.2px;
  }
  .captura-title em { font-style: italic; color: var(--green-500); font-weight: 500; }
  .captura-sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 22px;
  }
  .captura-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 18px;
  }
  .captura-field {
    display: flex;
    flex-direction: column;
  }
  .captura-field-full {
    grid-column: 1 / -1;
  }
  .captura-field-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold-500);
    margin-bottom: 8px;
    font-weight: 600;
  }
  .captura-input {
    font-family: var(--sans);
    font-size: 14px;
    padding: 10px 12px;
    border: 1px solid var(--line);
    background: white;
    color: var(--text-body);
    outline: none;
    transition: border-color 0.2s;
  }
  .captura-input:focus { border-color: var(--gold-500); }
  .captura-textarea {
    font-family: var(--sans);
    font-size: 14px;
    padding: 12px 14px;
    border: 1px solid var(--line);
    background: white;
    color: var(--text-body);
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
    min-height: 100px;
    line-height: 1.6;
  }
  .captura-textarea:focus { border-color: var(--gold-500); }
  .captura-status-row {
    display: flex;
    gap: 12px;
    margin-bottom: 18px;
  }
  .captura-status-btn {
    flex: 1;
    padding: 10px 14px;
    background: white;
    border: 1px solid var(--line);
    cursor: pointer;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 600;
    transition: all 0.2s;
  }
  .captura-status-btn:hover {
    border-color: var(--green-500);
    color: var(--navy-900);
  }
  .captura-status-btn.active {
    background: var(--green-500);
    color: white;
    border-color: var(--green-500);
  }
  .captura-saved {
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--green-500);
    font-weight: 600;
    text-align: right;
    margin-top: 10px;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .captura-saved.visible { opacity: 1; }


