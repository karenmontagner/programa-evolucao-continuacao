<script>
(function () {
  'use strict';

  var STORAGE_KEY = 'luciana_plano_semana05';
  var CYCLE_LABEL = '11 jun → 24 jun';

  var tasks = Array.prototype.slice.call(document.querySelectorAll('.task'));
  var metrics = Array.prototype.slice.call(document.querySelectorAll('.metric-input'));
  var progressFill = document.getElementById('progressFill');
  var progressPct = document.getElementById('progressPct');

  /* ---------- estado ---------- */
  function readState() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; }
    catch (e) { return {}; }
  }
  function writeState(state) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }
    catch (e) {}
  }

  function collectState() {
    var done = [];
    tasks.forEach(function (t, i) { if (t.classList.contains('done')) done.push(i); });
    var m = {};
    metrics.forEach(function (el) {
      var key = el.getAttribute('data-metric') || '';
      if (key && el.value) m[key] = el.value;
    });
    return { done: done, metrics: m };
  }

  function applyState(state) {
    state = state || {};
    var done = state.done || [];
    tasks.forEach(function (t, i) {
      if (done.indexOf(i) !== -1) t.classList.add('done');
      else t.classList.remove('done');
    });
    var m = state.metrics || {};
    metrics.forEach(function (el) {
      var key = el.getAttribute('data-metric') || '';
      el.value = (key && m[key] != null) ? m[key] : '';
    });
    updateProgress();
  }

  function persist() { writeState(collectState()); }

  /* ---------- progresso ---------- */
  function updateProgress() {
    var total = tasks.length;
    var done = tasks.filter(function (t) { return t.classList.contains('done'); }).length;
    var pct = total ? Math.round((done / total) * 100) : 0;
    if (progressFill) progressFill.style.width = pct + '%';
    if (progressPct) progressPct.textContent = pct + '%';
  }

  /* ---------- tarefas ---------- */
  tasks.forEach(function (t) {
    t.addEventListener('click', function () {
      t.classList.toggle('done');
      updateProgress();
      persist();
    });
  });

  metrics.forEach(function (el) {
    el.addEventListener('input', persist);
    el.addEventListener('click', function (e) { e.stopPropagation(); });
  });

  /* ---------- reset ---------- */
  var resetBtn = document.getElementById('resetBtn');
  if (resetBtn) resetBtn.addEventListener('click', function () {
    if (!confirm('Resetar todo o progresso desta quinzena?')) return;
    tasks.forEach(function (t) { t.classList.remove('done'); });
    metrics.forEach(function (el) { el.value = ''; });
    updateProgress();
    persist();
  });

  /* ---------- exportar PDF ---------- */
  var exportBtn = document.getElementById('exportBtn');
  if (exportBtn) exportBtn.addEventListener('click', function () { window.print(); });

  /* ---------- acordeão: expandir / fechar tudo ---------- */
  var accordions = Array.prototype.slice.call(document.querySelectorAll('details.section-acc'));
  var expandAllBtn = document.getElementById('expandAllBtn');
  var collapseAllBtn = document.getElementById('collapseAllBtn');
  if (expandAllBtn) expandAllBtn.addEventListener('click', function () {
    accordions.forEach(function (d) { d.open = true; });
  });
  if (collapseAllBtn) collapseAllBtn.addEventListener('click', function () {
    accordions.forEach(function (d) { d.open = false; });
  });

  /* ---------- modal compartilhar ---------- */
  var overlay = document.getElementById('shareOverlay');
  var shareBtn = document.getElementById('shareBtn');
  var shareClose = document.getElementById('shareClose');
  var shareOutput = document.getElementById('shareOutput');
  var shareInput = document.getElementById('shareInput');
  var generateBtn = document.getElementById('generateBtn');
  var copyBtn = document.getElementById('copyBtn');
  var importBtn = document.getElementById('importBtn');
  var copyFeedback = document.getElementById('copyFeedback');
  var importFeedback = document.getElementById('importFeedback');

  function openModal() { if (overlay) overlay.classList.add('active'); }
  function closeModal() { if (overlay) overlay.classList.remove('active'); }

  if (shareBtn) shareBtn.addEventListener('click', openModal);
  if (shareClose) shareClose.addEventListener('click', closeModal);
  if (overlay) overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });

  function encodeState(state) {
    var json = JSON.stringify(state);
    return btoa(unescape(encodeURIComponent(json)));
  }
  function decodeState(code) {
    var json = decodeURIComponent(escape(atob(code.trim())));
    return JSON.parse(json);
  }

  if (generateBtn) generateBtn.addEventListener('click', function () {
    var payload = collectState();
    payload.cycle = CYCLE_LABEL;
    if (shareOutput) shareOutput.value = encodeState(payload);
  });

  function showFeedback(el) {
    if (!el) return;
    el.classList.add('visible');
    setTimeout(function () { el.classList.remove('visible'); }, 2400);
  }

  if (copyBtn) copyBtn.addEventListener('click', function () {
    if (!shareOutput || !shareOutput.value) return;
    shareOutput.select();
    var ok = false;
    try { ok = document.execCommand('copy'); } catch (e) {}
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(shareOutput.value).then(function () {
        showFeedback(copyFeedback);
      }, function () { if (ok) showFeedback(copyFeedback); });
    } else if (ok) {
      showFeedback(copyFeedback);
    }
  });

  if (importBtn) importBtn.addEventListener('click', function () {
    if (!shareInput || !shareInput.value.trim()) return;
    try {
      var state = decodeState(shareInput.value);
      applyState(state);
      persist();
      if (importFeedback) {
        importFeedback.textContent = 'Progresso importado.';
        importFeedback.classList.remove('error');
        showFeedback(importFeedback);
      }
    } catch (e) {
      if (importFeedback) {
        importFeedback.textContent = 'Código inválido.';
        importFeedback.classList.add('error');
        showFeedback(importFeedback);
      }
    }
  });

  /* ---------- impressão: abrir tudo ---------- */
  var savedOpen = [];
  window.addEventListener('beforeprint', function () {
    savedOpen = accordions.map(function (d) { return d.open; });
    accordions.forEach(function (d) { d.open = true; });
  });
  window.addEventListener('afterprint', function () {
    accordions.forEach(function (d, i) { d.open = savedOpen[i]; });
  });

  /* ---------- init ---------- */
  applyState(readState());
})();
</script>
